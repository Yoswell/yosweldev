---
import AngleArrowIcon from '@/components/utils/icons/AngleArrowIcon.astro'

const { ...props } = Astro.props
---

<a
    href={ props.href }
    target='_blank'
    aria-label={`Loaded external resource ~ ${ props.href }`}
    class={ Astro.props.class }>

    <slot />

    { props.arrow && <AngleArrowIcon class='absolute top-3 right-3 text-(--fg3) rotate-45 size-4 stroke-2 group-hover:text-white ease-in-out duration-200' /> }
</a>
