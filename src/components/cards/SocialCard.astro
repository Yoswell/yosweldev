---
import AngleArrowIcon from '@/components/utils/icons/AngleArrowIcon.astro'
import Anchor from '@/components/utils/Anchor.astro'
import TypoMono from '@/components/utils/TypoMono.astro'

const { ...props } = Astro.props
---

<Anchor
    href={ props.href }
    target='_blank'
    rel='noopener noreferrer'
    class={ Astro.props.class }>

    <slot />
    
    <article>
        <h6 class='text-white'>
            { props.head }
        </h6>
        <TypoMono class='block text-(--fg2) text-xs font-mono mt-1.25 whitespace-nowrap'>
            { props.content }
        </TypoMono>
    </article>
    
    { props.arrow && <AngleArrowIcon class='absolute top-3 right-3 text-(--fg3) rotate-45 size-4 stroke-2 group-hover:text-white ease-in-out duration-200' /> }
</Anchor>
