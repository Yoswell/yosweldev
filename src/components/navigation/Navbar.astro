---
import Anchor from '@/components/utils/Anchor.astro'
import FloatQuickLinks from '@/components/navigation/FloatQuickLinks.astro'

import { PAGES_LIST } from '@/const/Pages_list'
---

<header class='w-full flex items-center justify-center bg-(--bg0)/80 backdrop-blur-lg border-b border-(--br2) py-2.75 px-4 sm:px-4 xl:px-0 sticky top-0 z-100'>
    <nav class='sm:max-w-5xl lg:max-w-7xl w-full flex items-center justify-between gap-2'>
        <h1 class='text-xl font-logo'>
            了osweldev
        </h1>

        <ul class='flex items-center gap-5 leading-none'>
            {PAGES_LIST.map((page) => (
                <li>
                    <Anchor 
                        href={ page.href }
                        class='text-white'>
                        
                        <span>
                            { page.content }
                        </span>
                    </Anchor>
                </li>
            ))}

            <li class='relative'>
                <FloatQuickLinks />
            </li>
        </ul>
    </nav>
</header>