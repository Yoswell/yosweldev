---
import FloatPaperBanner from "@/components/FloatPaperBanner.astro"

const { title } = Astro.props

const { pathname } = Astro.url;

const PATHS_TO_SHOW_BANNER = [
	'/about',
	'/about/',
	'/links',
	'/links/',
	'/uses',
	'/uses/',
	'/uned',
	'/uned/',
	'/attribution',
	'/attribution/',
	'/contact',
	'/contact/'
];
---

<!DOCTYPE html>
<html lang='en'>
	<head>
		<meta charset='UTF-8' />
		<meta name='viewport' content='width=device-width, initial-scale=1, viewport-fit=cover' />

		<meta name='title' content='Yoswel ~ X-Force Penetration Tester ~ Full-Stack Developer ~ Personal Portfolio' />
		<meta name='description' content='Personal portfolio of Yoswel - Software Developer & Creative Technologist. Explore projects, skills, and professional journey'/>
		<meta name='keywords' content='Yoswel, portfolio, software developer, creative technologist, web development, programming, personal website'/>
		<meta name='author' content='Yoswel' />
		<meta name='robots' content='index, follow' />

		<meta property='og:type' content='website' />
		<meta property='og:url' content='https://yosweldev.vercel.app' />
		<meta property='og:title' content='Yoswel ~ X-Force Penetration Tester ~ Full-Stack Developer ~ Personal Portfolio' />
		<meta property='og:description' content='Personal portfolio of Yoswel - Software Developer & Creative Technologist. Explore projects, skills, and professional journey' />

		<meta name='theme-color' content='#000000' media='(prefers-color-scheme: dark)' />
		<meta name='theme-color' content='#ffffff' media='(prefers-color-scheme: light)' />
		<meta name='color-scheme' content='dark light' />

