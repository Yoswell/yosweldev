		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "Person",
				"name": "Yoswel",
				"url": "https://yosweldev.vercel.app",
				"jobTitle": "X-Force Penetration Tester & Full-Stack Developer",
